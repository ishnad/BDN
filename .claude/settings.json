{
  "hooks": {
    "PreToolUse": [
      {
        "type": "command",
        "command": "bash scripts/hooks/pre-tool-use.sh",
        "windows": "powershell -ExecutionPolicy Bypass -File scripts/hooks/pre-tool-use.ps1",
        "timeout": 10
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "command": "bash scripts/hooks/post-tool-use.sh",
        "windows": "powershell -ExecutionPolicy Bypass -File scripts/hooks/post-tool-use.ps1",
        "timeout": 10
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "bash scripts/hooks/on-stop.sh",
        "windows": "powershell -ExecutionPolicy Bypass -File scripts/hooks/on-stop.ps1",
        "timeout": 30
      }
    ]
  },
  "mcpServers": {
    "project-tools": {
      "command": "node",
      "args": ["./mcp-servers/project-tools/dist/index.js"]
    },
    "supabase": {
      "type": "http",
      "url": "https://mcp.supabase.com/mcp?project_ref=mlcmeorshvxtimrousqh"
    }
  },
  "permissions": {
    "allow": [
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(git:*)",
      "Bash(node:*)",
      "Bash(next:*)"
    ]
  }
}
